{
  "name": "flipcard-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "FlipCard — the first primitive in an adaptive, manifest schema-driven, composable UI system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/flipcard.git"
  },
  "homepage": "https://microsoft.github.io/flipcard/",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build:libs && npm run build:showcase",
    "build:libs": "npm run build -w @microsoft/flipcard-core && npm run build -w @microsoft/flipcard-themes && npm run build -w @microsoft/flipcard-react -w @microsoft/flipcard && npm run build -w @microsoft/flipcard-mcp",
    "build:showcase": "npm run build -w @microsoft/flipcard-showcase",
    "build:flipdeck": "flipdeck build -o flipdeck-static",
    "dev": "npm run dev -w @microsoft/flipcard-showcase",
    "flipdeck": "flipdeck dev -p 6006",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,html}\"",
    "typecheck": "tsc -p packages/core/tsconfig.json --noEmit && tsc -p packages/themes/tsconfig.json --noEmit && tsc -p packages/mcp-server/tsconfig.json --noEmit && tsc -p packages/react/tsconfig.json --noEmit && tsc -p packages/vanilla/tsconfig.json --noEmit && tsc -p apps/showcase/tsconfig.json --noEmit",
    "clean": "rimraf --glob \"packages/*/dist\" \"apps/*/dist\" flipdeck-static .turbo"
  },
  "devDependencies": {
    "@flipdeck/addon-essentials": "^8.4.7",
    "@flipdeck/addon-interactions": "^8.4.7",
    "@flipdeck/blocks": "^8.4.7",
    "@flipdeck/react": "^8.4.7",
    "@flipdeck/react-vite": "^8.4.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-flipdeck": "^0.11.2",
    "globals": "^15.14.0",
    "happy-dom": "^20.8.9",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "flipdeck": "^8.4.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "pngjs": "^7.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "uuid": "^14.0.0"
  }
}
