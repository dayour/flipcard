{
  "name": "adaptive-slide",
  "version": "0.2.0",
  "description": "A schema-driven presentation builder/viewer built on Adaptive Cards with MCP App support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "adaptive-slide-server": "./dist/plugins/mcp-app/server.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "cp src/plugins/mcp-app/viewer.html dist/plugins/mcp-app/viewer.html",
    "validate": "node scripts/validate.js",
    "test": "node --test tests/*.test.js",
    "lint": "tsc --noEmit",
    "serve": "node dist/plugins/mcp-app/server.js",
    "dev": "tsx src/plugins/mcp-app/server.ts"
  },
  "keywords": [
    "adaptive-cards",
    "presentation",
    "slides",
    "schema",
    "json-schema",
    "mcp",
    "mcp-app"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
